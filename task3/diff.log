diff --git a/modules/embassy-preempt-event/src/os_mutex.rs b/modules/embassy-preempt-event/src/os_mutex.rs
index 8b1378917..bd2924bd0 100644
--- a/modules/embassy-preempt-event/src/os_mutex.rs
+++ b/modules/embassy-preempt-event/src/os_mutex.rs
@@ -1 +1,218 @@
+use core::sync::atomic::Ordering;
 
+use embassy_preempt_cfg::ucosii::{OSIntNesting, OS_ERR_STATE, OS_DEL_NO_PEND, OS_DEL_ALWAYS};
+use embassy_preempt_executor::GlobalSyncExecutor;
+use embassy_preempt_executor::os_time::OSTimeDly;
+use crate::{GlobalEventPool, OS_EVENT_REF, OS_EVENT_TYPE};
+use crate::{OS_EventTaskWait, OS_EventTaskRdy};
+
+/// Create a mutual exclusion semaphore (mutex).
+///
+/// # Arguments
+/// * `prio_ceil` — Priority Ceiling Priority. Use 0xFF to disable priority ceiling.
+///
+/// # Returns
+/// `Some(OS_EVENT_REF)` on success, `None` if called from ISR or pool exhausted.
+pub fn OSMutexCreate(prio_ceil: u8) -> Option<OS_EVENT_REF> {
+    // See if called from ISR
+    if OSIntNesting.load(Ordering::Acquire) > 0 {
+        return None;
+    }
+    let globaleventpool = GlobalEventPool().as_ref().unwrap();
+    let pevent = globaleventpool.alloc();
+    let mut pevent = pevent?;
+
+    unsafe {
+        if pevent.ptr.is_some() {
+            pevent.OSEventType = OS_EVENT_TYPE::MUTEX;
+            // OSEventCnt = 0xFFFF means mutex is available.
+            // High byte 0xFF = available, Low byte 0xFF = no owner.
+            pevent.OSEventCnt = 0xFFFF;
+            // Store priority ceiling
+            pevent.OSEventPCP = prio_ceil;
+            // Unlink from ECB free list
+            pevent.OSEventPtr.set(None);
+        }
+    }
+    // Initialize to 'nobody waiting' on mutex
+    pevent.OS_EventWaitListInit();
+    return Some(pevent);
+}
+
+/// Acquire a mutex without blocking.
+///
+/// # Returns
+/// - `1` if the mutex was successfully acquired
+/// - `0` if the mutex is already held or event type is wrong
+pub fn OSMutexAccept(mut pevent: OS_EVENT_REF) -> u8 {
+    // Validate event block type
+    if pevent.OSEventType != OS_EVENT_TYPE::MUTEX {
+        return 0;
+    }
+    let result = critical_section::with(|_| {
+        let cnt = pevent.OSEventCnt;
+        // High byte == 0xFF means mutex is available
+        if (cnt >> 8) == 0xFF {
+            let executor = GlobalSyncExecutor().as_ref().unwrap();
+            let cur_prio = unsafe { *executor.OSPrioCur.get_unmut() };
+            // Acquire mutex: store current task's priority in low byte, clear high byte
+            pevent.OSEventCnt = (cur_prio as u16) & 0x00FF;
+            return 1;
+        }
+        return 0;
+    });
+    return result;
+}
+
+/// Wait for a mutex.
+///
+/// # Arguments
+/// * `pevent` — Pointer to the mutex event control block.
+/// * `timeout` — Timeout in ticks (0 = no timeout).
+///
+/// # Returns
+/// `OS_ERR_NONE` on success, or an error code.
+pub fn OSMutexPend(mut pevent: OS_EVENT_REF, timeout: u16) -> OS_ERR_STATE {
+    #[cfg(feature = "OS_ARG_CHK_EN")]
+    {
+        if pevent.ptr.is_none() {
+            return OS_ERR_STATE::OS_ERR_PEVENT_NULL;
+        }
+    }
+    // Validate event block type
+    if pevent.OSEventType != OS_EVENT_TYPE::MUTEX {
+        return OS_ERR_STATE::OS_ERR_EVENT_TYPE;
+    }
+    // See if called from ISR
+    if OSIntNesting.load(Ordering::Acquire) > 0 {
+        return OS_ERR_STATE::OS_ERR_PEND_ISR;
+    }
+    let result = critical_section::with(|_| {
+        // Check if mutex is available (high byte == 0xFF)
+        if (pevent.OSEventCnt >> 8) == 0xFF {
+            let executor = GlobalSyncExecutor().as_ref().unwrap();
+            let cur_prio = unsafe { *executor.OSPrioCur.get_unmut() };
+            // Acquire mutex
+            pevent.OSEventCnt = (cur_prio as u16) & 0x00FF;
+            return OS_ERR_STATE::OS_ERR_NONE;
+        }
+        // Mutex is held — suspend task until mutex is released or timeout occurs
+        OS_EventTaskWait(pevent);
+        // Exiting the ready queue, releasing control of the CPU
+        OSTimeDly(timeout as u64);
+        return OS_ERR_STATE::OS_ERR_NONE;
+    });
+    return result;
+}
+
+/// Release a mutex.
+///
+/// # Returns
+/// `OS_ERR_NONE` on success, `OS_ERR_NOT_MUTEX_OWNER` if the calling task
+/// does not own the mutex, or another error code.
+pub fn OSMutexPost(mut pevent: OS_EVENT_REF) -> OS_ERR_STATE {
+    #[cfg(feature = "OS_ARG_CHK_EN")]
+    {
+        if pevent.ptr.is_none() {
+            return OS_ERR_STATE::OS_ERR_PEVENT_NULL;
+        }
+    }
+    // Validate event block type
+    if pevent.OSEventType != OS_EVENT_TYPE::MUTEX {
+        return OS_ERR_STATE::OS_ERR_EVENT_TYPE;
+    }
+    // Verify ownership: the calling task must own the mutex
+    let executor = GlobalSyncExecutor().as_ref().unwrap();
+    let cur_prio = unsafe { *executor.OSPrioCur.get_unmut() };
+    if (pevent.OSEventCnt & 0xFF) as u8 != cur_prio {
+        return OS_ERR_STATE::OS_ERR_NOT_MUTEX_OWNER;
+    }
+
+    let result = critical_section::with(|_| {
+        // See if any tasks are waiting for the mutex
+        if pevent.OSEventGrp != 0 {
+            // Make the highest-priority waiting task ready
+            OS_EventTaskRdy(pevent);
+            unsafe { GlobalSyncExecutor().as_ref().unwrap().IntCtxSW(); }
+            return OS_ERR_STATE::OS_ERR_NONE;
+        }
+        // No tasks waiting — release mutex
+        pevent.OSEventCnt = 0xFFFF;
+        return OS_ERR_STATE::OS_ERR_NONE;
+    });
+    return result;
+}
+
+/// Delete a mutex.
+///
+/// # Arguments
+/// * `pevent` — Pointer to the mutex event control block.
+/// * `opt` — `OS_DEL_NO_PEND` (delete only if no tasks waiting) or
+///           `OS_DEL_ALWAYS` (delete even if tasks are waiting).
+///
+/// # Returns
+/// Tuple of `(OS_ERR_STATE, OS_EVENT_REF)`. On success, the returned
+/// `OS_EVENT_REF` is default (ptr = None).
+pub fn OSMutexDel(mut pevent: OS_EVENT_REF, opt: u8) -> (OS_ERR_STATE, OS_EVENT_REF) {
+    let mut pevent_return: OS_EVENT_REF = OS_EVENT_REF::default();
+    #[cfg(feature = "OS_ARG_CHK_EN")]
+    {
+        if pevent.ptr.is_none() {
+            return (OS_ERR_STATE::OS_ERR_PEVENT_NULL, pevent);
+        }
+    }
+    // Validate event block type
+    if pevent.OSEventType != OS_EVENT_TYPE::MUTEX {
+        return (OS_ERR_STATE::OS_ERR_EVENT_TYPE, pevent);
+    }
+    // See if called from ISR
+    if OSIntNesting.load(Ordering::Acquire) > 0 {
+        return (OS_ERR_STATE::OS_ERR_DEL_ISR, pevent);
+    }
+    let mut tasks_waiting: bool = false;
+    let result = critical_section::with(|_| {
+        // See if any tasks waiting on mutex
+        if pevent.OSEventGrp != 0 {
+            tasks_waiting = true;
+        } else {
+            tasks_waiting = false;
+        }
+
+        match opt as u32 {
+            OS_DEL_NO_PEND => {
+                if tasks_waiting == false {
+                    GlobalEventPool().as_ref().unwrap().free(pevent);
+                    pevent.OSEventCnt = 0;
+                    pevent_return = OS_EVENT_REF::default();
+                    return OS_ERR_STATE::OS_ERR_NONE;
+                } else {
+                    pevent_return = pevent;
+                    return OS_ERR_STATE::OS_ERR_TASK_WAITING;
+                }
+            }
+            OS_DEL_ALWAYS => {
+                while pevent.OSEventGrp != 0 {
+                    OS_EventTaskRdy(pevent);
+                }
+                GlobalEventPool().as_ref().unwrap().free(pevent);
+                pevent.OSEventCnt = 0;
+                // Reschedule only if task(s) were waiting
+                if tasks_waiting {
+                    unsafe {
+                        GlobalSyncExecutor().as_ref().unwrap().IntCtxSW();
+                    }
+                }
+                pevent_return = OS_EVENT_REF::default();
+                return OS_ERR_STATE::OS_ERR_NONE;
+            }
+            _ => {
+                pevent_return = pevent;
+                return OS_ERR_STATE::OS_ERR_INVALID_OPT;
+            }
+        }
+    });
+    if result != OS_ERR_STATE::OS_ERR_NONE {
+        return (result, pevent_return);
+    }
+    return (OS_ERR_STATE::OS_ERR_NONE, pevent_return);
+}
